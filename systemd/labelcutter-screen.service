[Unit]
Description=Label Cutter Screen (GRBL touchscreen UI)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
WorkingDirectory=/home/pi/labelcutter_screen
ExecStart=/usr/bin/python3 /home/pi/labelcutter_screen/main.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical.target
